# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s

# --- Database (Postgres) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=diffinder
DB_USER=diffinder
DB_PASSWORD=diffinder
DB_SSLMODE=disable
DB_MAX_CONNS=10

# --- Auth (JWT HS256) ---
# Generare con: openssl rand -base64 48
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# --- Webhook GitHub ---
# Stesso secret configurato in GitHub Actions per X-Hub-Signature-256
GITHUB_WEBHOOK_SECRET=change-me-webhook-shared-secret

# --- CORS (dev) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json

# --- Seed ---
SEED_ADMIN_EMAIL=admin@diffinder.local
SEED_ADMIN_PASSWORD=admin123
